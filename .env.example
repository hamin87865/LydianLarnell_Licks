# 실제 실행 폴더: Lydian_Larnell_Licks
DATABASE_URL=postgresql://postgres:password@localhost:5432/lydian_larnell_licks

# 운영 환경에서는 반드시 32자 이상의 랜덤 문자열 사용
SESSION_SECRET=change-this-to-a-long-random-secret-at-least-32-characters

# development | production
NODE_ENV=development
NODE_VERSION=22

# DB SSL 모드: auto | disable | require
DB_SSL_MODE=auto

# Render Persistent Disk mount path 하위 경로 사용
UPLOAD_ROOT=/var/data/uploads

# 세션 쿠키 SameSite: lax | none
SESSION_SAME_SITE=lax

# 메일 발송 (이메일 인증 / 비밀번호 재설정 / 구독 알림)
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# 배포 CORS / HTTPS 허용 도메인
CLIENT_URL=http://localhost:5000
CLIENT_URL_WWW=
RENDER_EXTERNAL_URL=
FRONTEND_URL=http://localhost:5000
APP_BASE_URL=http://localhost:5000

# 기본 관리자 자동 생성
# 운영에서는 false 권장. 꼭 필요할 때만 true로 켜고 강한 비밀번호 지정
CREATE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeThisAdminPassword123!
DEFAULT_ADMIN_NAME=시스템 관리자
SKIP_DEFAULT_ADMIN=false
ALLOW_PRODUCTION_DEFAULT_ADMIN_CREATE=false
FEATURE_ALLOW_VIDEO_FILE_UPLOAD=false

# 결제 (토스페이먼츠)
VITE_TOSS_PAYMENTS_CLIENT_KEY=test_gck_your_widget_client_key
TOSS_CLIENT_KEY=test_gck_your_widget_client_key
TOSS_SECRET_KEY=test_sk_your_secret_key
TOSS_PAYMENTS_SECRET_KEY=test_sk_your_secret_key
TOSS_PAYMENTS_WEBHOOK_SECRET=

# 계좌번호 암호화 키 (운영 필수, 32자 이상 권장)
ACCOUNT_ENCRYPTION_KEY=replace-with-32-plus-char-random-secret

# 오류 모니터링 / 관리자 알림
SENTRY_DSN=
ADMIN_ALERT_EMAIL_TO=admin@example.com
ADMIN_ALERT_EMAIL_FROM=

# 운영 점검 / 실행형 E2E
VERIFY_BASE_URL=http://localhost:5000
E2E_BASE_URL=http://localhost:5000
TOSS_TEST_PAYMENT_KEY=
TOSS_TEST_ORDER_ID=
TOSS_TEST_AMOUNT=
E2E_TOSS_LOGIN_EMAIL=
E2E_TOSS_LOGIN_PASSWORD=
E2E_TOSS_PAYMENT_KEY=
E2E_TOSS_ORDER_ID=
E2E_TOSS_AMOUNT=
